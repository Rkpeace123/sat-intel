# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://satark:satark@localhost:5432/satark

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security — CHANGE THIS before any deployment ──────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
# JWT_ALG=HS256
# JWT_EXPIRE_MINUTES=720

# ── Assist lane (local / sovereign) ───────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
GEMMA_MODEL=gemma2:2b
# EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# RERANKER_MODEL=BAAI/bge-reranker-base
# CHROMA_DIR=data/chroma

# ── Intelligence thresholds ───────────────────────────────────────────────────
CONF_THRESHOLD=70

# ── MoSPI DIID NIC (production endpoint; leave blank for local dev) ───────────
DIID_NIC_URL=

# ── Sarvam voice (production key) ────────────────────────────────────────────
SARVAM_API_KEY=

# ── Feature flags (off by default; EN/HI/TA static i18n works without these) ─
ENABLE_TRANSLATION=false      # true = live IndicTrans2 (roadmap)
ENABLE_VOICE=false            # true = Sarvam STT/TTS (needs SARVAM_API_KEY)
